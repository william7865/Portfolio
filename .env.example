# Resend (https://resend.com — sign up, copy API key, 100 emails/month free)
RESEND_API_KEY=re_xxxxxxxx
CONTACT_TO_EMAIL=your-inbox@example.com
CONTACT_FROM_EMAIL=onboarding@resend.dev

# Public base URL, used for canonical URLs and JSON-LD.
NEXT_PUBLIC_BASE_URL=https://example.com

# Neon Postgres. Also backs the shared rate-limit counters on /api/login and
# /api/contact — without it those fall back to per-instance in-memory counting.
# Run `npm run db:init` once to create the tables.
DATABASE_URL=postgres://user:pass@host/db?sslmode=require

# Dashboard access. Rotating DASHBOARD_PASSWORD invalidates every session cookie
# already issued, so it doubles as "log out everywhere".
# Generate both with: openssl rand -hex 32
DASHBOARD_PASSWORD=
SESSION_SECRET=
